    <update_contact>bryan.hyland32@gmail.com</update_contact>
    <url type="homepage">https://github.com/pop-os/cosmic-viewer</url>
    <url type="bugtracker">https://github.com/pop-os/cosmic-viewer/issues</url>
    <name>COSMIC Viewer</name>
    <summary>Image viewer for the COSMIC desktop</summary>
    <description>
        <p>
            COSMIC Viewer is an image viewer and markup tool for the COSMIC desktop environment.
            It opens a wide range of formats and provides quick navigation, non-destructive editing, and markup tools.
        </p>
        <p
        >COSMIC Viewer opens a wide range of formats and provides quick navigation, non-destructive editing, and markup tools</p>
        <ul>
            <li
            >Opens JPEG, PNG, GIF, WebP, BMP, TIFF, ICO, AVIF, HEIF/HEIC, JPEG XL, SVG and the netpbm and Farbfeld families</li>
            <li>Zoom, pan, and fit-to-window viewer with EXIF-aware display</li>
            <li>Thumbnail navigation through a folder</li>
            <li>Crop and rotate</li>
            <li>Markup with pen, highlighter, shapes, and text</li>
            <li>Set an image as the desktop wallpaper</li>
            <li
            >Copy an image to system clipboard and paste it in another application</li>
        </ul>
    </description>
    <keywords>
        <keyword>Image</keyword>
        <keyword>Photo</keyword>
        <keyword>Picture</keyword>
        <keyword>Viewer</keyword>
        <keyword>Annotate</keyword>
        <keyword>Markup</keyword>
    </keywords>
    <launchable type="desktop-id">com.system76.CosmicViewer.desktop</launchable>
    <icon
        type="remote"
        height="256"
        width="256"
    >https://github.com/pop-os/cosmic-viewer/raw/branch/main/data/icons/com.system76.CosmicViewer-256.svg</icon>
